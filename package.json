{
  "name": "@vizora/source",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "build": "nx build @vizora/middleware && nx build @vizora/realtime && cd web && npx next build",
    "build:middleware": "nx build @vizora/middleware",
    "build:web": "nx build @vizora/web",
    "build:realtime": "nx build @vizora/realtime",
    "dev": "nx run-many --target=serve --all --parallel",
    "test": "nx run-many --target=test --all",
    "test:ops": "node --import tsx --test \"scripts/ops/**/*.test.ts\"",
    "test:e2e": "pnpm --filter @vizora/middleware test:e2e",
    "smoke:email-readiness": "node scripts/smoke/email-readiness.mjs",
    "e2e:customer-critical": "node scripts/smoke/playwright-customer-critical.mjs",
    "security:no-hardcoded-jwts": "node scripts/security/check-no-hardcoded-jwts.js",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint --ext .ts,.tsx middleware/src realtime/src",
    "lint:web": "pnpm --filter @vizora/web exec next lint"
  },
  "private": true,
  "pnpm": {
    "overrides": {
      "minimatch@<3.1.5": "3.1.5",
      "minimatch@>=5.0.0 <5.1.8": "5.1.8",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "minimatch@>=10.0.0 <10.2.3": "10.2.3",
      "serialize-javascript@<=7.0.2": "7.0.4",
      "tar@<=7.5.9": "7.5.10",
      "rollup@>=4.0.0 <4.59.0": "4.59.0",
      "koa@>=3.0.0 <3.1.2": "3.1.2",
      "svgo@>=3.0.0 <3.3.3": "3.3.3",
      "immutable@>=5.0.0 <5.1.5": "5.1.5",
      "multer@<2.2.0": "2.2.0",
      "undici@>=7.0.0 <7.28.0": "7.28.0",
      "socket.io-parser@>=4.0.0 <4.2.6": "4.2.6",
      "fast-xml-parser@<5.7.3": "5.7.3",
      "fast-xml-builder@<=1.1.6": "1.1.7",
      "path-to-regexp@<0.1.13": "0.1.13",
      "path-to-regexp@>=8.0.0 <8.4.0": "8.4.0",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "lodash@>=4.0.0 <4.18.0": "4.18.0",
      "lodash-es@>=4.0.0 <4.18.0": "4.18.0",
      "fast-uri@<3.1.2": "3.1.2",
      "ws@>=8.0.0 <8.21.0": "8.21.0",
      "form-data@>=4.0.0 <4.0.6": "4.0.6",
      "hono@<4.12.25": "4.12.25"
    },
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "sharp",
      "esbuild",
      "@swc/core",
      "nx",
      "@parcel/watcher",
      "msgpackr-extract",
      "unrs-resolver",
      "puppeteer"
    ],
    "auditConfig": {}
  },
  "devDependencies": {
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/js": "22.4.2",
    "@nx/nest": "^22.4.2",
    "@nx/next": "^22.4.2",
    "@nx/node": "^22.4.2",
    "@nx/web": "22.4.2",
    "@nx/webpack": "22.4.2",
    "@playwright/test": "^1.58.0",
    "@swc-node/register": "~1.9.1",
    "@swc/cli": "~0.6.0",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@types/node": "20.19.9",
    "@types/nodemailer": "^8.0.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sanitize-html": "^2.16.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "electron": "^28.3.3",
    "eslint": "^9.39.2",
    "nodemailer": "^9.0.1",
    "nx": "22.4.2",
    "playwright": "^1.58.0",
    "prettier": "~3.6.2",
    "puppeteer": "^24.37.5",
    "swc-loader": "0.1.15",
    "tslib": "^2.3.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.1.12",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.12",
    "@vizora/database": "workspace:*",
    "axios": "^1.18.1",
    "dotenv": "^17.2.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "sanitize-html": "^2.17.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3"
  }
}
